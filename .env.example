# Node 1 (required) — legacy LND_* vars also work for node 1
LND_NODE_1_NAME=alice
LND_NODE_1_HOST=localhost:10001
LND_NODE_1_TLS_CERT_PATH=
LND_NODE_1_MACAROON_PATH=

# Node 2 (optional — Polar Bob)
LND_NODE_2_NAME=bob
LND_NODE_2_HOST=localhost:10002
LND_NODE_2_TLS_CERT_PATH=
LND_NODE_2_MACAROON_PATH=

# Node 3 (optional — Polar Carol)
LND_NODE_3_NAME=carol
LND_NODE_3_HOST=localhost:10003
LND_NODE_3_TLS_CERT_PATH=
LND_NODE_3_MACAROON_PATH=

# Legacy node 1 aliases (optional if LND_NODE_1_* is set)
# LND_HOST=localhost:10001
# LND_TLS_CERT_PATH=
# LND_MACAROON_PATH=

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
